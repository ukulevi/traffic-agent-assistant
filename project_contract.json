{
  "contract_version": "1.0.0",
  "updated_at": "2026-06-21",
  "project": {
    "name": "SmartTraffic What-If",
    "short_name": "STWI",
    "delivery_level": "13-week MVP",
    "decision_support_only": true,
    "automatic_actuation": false
  },
  "mvp_scope": {
    "functional_network_nodes": 20,
    "recorded_camera_streams_max": 20,
    "synthetic_camera_producers": 1000,
    "raw_video_retention": false
  },
  "data_contract": {
    "input_shape": "X[B,12,N,16]",
    "adjacency_shape": "A[N,N]",
    "missing_mask_shape": "M[B,12,N,16]",
    "forecast_shape": "Y[B,6,N,2]",
    "time_step_minutes": 5,
    "history_steps": 12,
    "forecast_steps": 6,
    "forecast_targets": [
      "traffic_volume_5m",
      "avg_speed_kmh"
    ],
    "features": [
      {"name": "traffic_volume_5m", "unit": "vehicles/5min", "encoding": "scaled_continuous"},
      {"name": "avg_speed_kmh", "unit": "km/h", "encoding": "scaled_continuous"},
      {"name": "heavy_vehicle_ratio", "unit": "ratio", "encoding": "bounded_ratio"},
      {"name": "co_ppm", "unit": "ppm", "encoding": "scaled_continuous"},
      {"name": "co2_ppm", "unit": "ppm", "encoding": "scaled_continuous"},
      {"name": "nox_ppb", "unit": "ppb", "encoding": "scaled_continuous"},
      {"name": "pm25_ugm3", "unit": "ug/m3", "encoding": "scaled_continuous"},
      {"name": "pm10_ugm3", "unit": "ug/m3", "encoding": "scaled_continuous"},
      {"name": "temperature_c", "unit": "degC", "encoding": "scaled_continuous"},
      {"name": "humidity_pct", "unit": "percent", "encoding": "scaled_continuous"},
      {"name": "wind_speed_ms", "unit": "m/s", "encoding": "scaled_continuous"},
      {"name": "time_of_day_sin", "unit": "unitless", "encoding": "cyclical"},
      {"name": "time_of_day_cos", "unit": "unitless", "encoding": "cyclical"},
      {"name": "day_of_week_sin", "unit": "unitless", "encoding": "cyclical"},
      {"name": "day_of_week_cos", "unit": "unitless", "encoding": "cyclical"},
      {"name": "green_time_ratio", "unit": "ratio", "encoding": "bounded_ratio"}
    ],
    "normalization": {
      "fit_on_training_split_only": true,
      "scale_continuous_only": true,
      "preserve_cyclical_and_ratio_features": true
    }
  },
  "models": {
    "baseline_forecaster": "GCN-LSTM",
    "baseline_purpose": "30-minute no-intervention forecast",
    "scenario_model": "heterogeneous surrogate ensemble",
    "scenario_training_source": "offline calibrated SUMO runs",
    "uncertainty_policy": "calibrated on held-out validation data",
    "out_of_distribution_policy": "retrieve evidence and return needs_review; never blend retrieved rows into online input"
  },
  "runtime": {
    "surrogate_p99_ms": 500,
    "e2e_p95_ms": 30000,
    "hard_deadline_p99_ms": 180000,
    "benchmark_profile": {
      "cpu_cores": 8,
      "ram_gb": 32,
      "gpu_vram_gb_min": 12,
      "gpu_vram_gb_max": 16
    }
  },
  "technology": {
    "workflow": "LangGraph",
    "job_worker": "Celery",
    "queue_and_progress": "Redis",
    "time_series_database": "TimescaleDB",
    "offline_analytics": "DuckDB",
    "vector_database": "Qdrant",
    "embedding_model": "BGE-m3",
    "api": "FastAPI",
    "progress_transport": "SSE"
  },
  "safety": {
    "mechanism": "Counterfactual Safety Loop",
    "positioning": "inspired by CF-VLA; not an end-to-end VLA model",
    "max_iterations": 3,
    "default_vc_threshold": 0.9,
    "vc_threshold_is_configurable_policy": true,
    "fail_closed": true,
    "human_approval_required": true
  },
  "api": {
    "create_job": "POST /api/v1/what-if-jobs",
    "get_job": "GET /api/v1/what-if-jobs/{job_id}",
    "events": "GET /api/v1/what-if-jobs/{job_id}/events",
    "create_status": 202,
    "statuses": ["queued", "running", "succeeded", "needs_review", "failed", "expired"],
    "successful_action_field": "recommended_action",
    "review_action_field": "candidate_action",
    "legal_evidence_field": "citations"
  },
  "legal_corpus": [
    {
      "number": "35/2024/QH15",
      "title": "Luật Đường bộ",
      "effective_from": "2025-01-01",
      "source_url": "https://vanban.chinhphu.vn/?pageid=27160&docid=211193"
    },
    {
      "number": "36/2024/QH15",
      "title": "Luật Trật tự, an toàn giao thông đường bộ",
      "effective_from": "2025-01-01",
      "source_url": "https://vanban.chinhphu.vn/?pageid=27160&docid=211194&classid=1&typegroupid=3"
    }
  ],
  "documentation_versions": {
    "00_STWI_Summary_and_Guidelines.md": "1.4",
    "01_System_Architecture_Data_Pipeline.md": "1.4",
    "02_ML_and_Simulation_Specification.md": "1.4",
    "03_Knowledge_Base_and_RAG_Design.md": "1.4",
    "04_AI_Agent_Orchestrator_CF_VLA.md": "1.4",
    "05_Implementation_Plan.md": "1.3"
  }
}
