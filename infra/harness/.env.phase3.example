# Copy to a private, ignored file. Do not commit real values.
STWI_HARNESS_BIND_ADDRESS=127.0.0.1
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
TSDB_PORT=5432
STWI_TSDB_DB=stwi
STWI_TSDB_ADMIN_USER=stwi_admin
STWI_TSDB_PASSWORD=replace-with-a-unique-admin-secret
STWI_READER_PASSWORD=replace-with-a-distinct-reader-secret
STWI_QDRANT_API_KEY=replace-with-a-write-api-key
STWI_QDRANT_READ_ONLY_API_KEY=replace-with-a-distinct-read-only-api-key

# Explicit test clients; do not use default credentials in test code.
STWI_QDRANT_URL=http://127.0.0.1:6333
STWI_TSDB_DSN=postgresql://stwi_reader_user:replace-with-a-distinct-reader-secret@127.0.0.1:5432/stwi
